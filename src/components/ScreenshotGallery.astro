---
import { site } from '../content/site';
---

<section class="section" id="screenshots" aria-labelledby="screenshots-heading">
  <div class="container">
    <h2 id="screenshots-heading">See it in action</h2>
  </div>
  <div class="gallery-track">
    <div class="gallery-fade-left"></div>
    <div class="gallery-fade-right"></div>
    <div class="gallery-scroll">
      {site.screenshots.map((screenshot) => (
        <figure class="gallery-card">
          <div class="gallery-image-wrap">
            <img
              src={screenshot.src}
              alt={screenshot.alt}
              loading="lazy"
              decoding="async"
              width="1320"
              height="2868"
            />
          </div>
          <figcaption>{screenshot.caption}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery-track {
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    overflow: hidden;
    position: relative;
  }

  .gallery-fade-left,
  .gallery-fade-right {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 60px;
    z-index: 2;
    pointer-events: none;
  }

  .gallery-fade-left {
    left: 0;
    background: linear-gradient(to right, var(--bg), transparent);
  }

  .gallery-fade-right {
    right: 0;
    background: linear-gradient(to left, var(--bg), transparent);
  }

  .gallery-scroll {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-inline: max(var(--content-padding), calc((100vw - var(--content-max)) / 2));
    padding-bottom: 1.5rem;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--surface-border) transparent;
  }

  .gallery-card {
    flex: 0 0 auto;
    width: clamp(280px, 35vw, 360px);
    scroll-snap-align: center;
  }

  .gallery-image-wrap {
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 1320 / 2868;
  }

  .gallery-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  figcaption {
    margin-top: 0.75rem;
    font-size: var(--small);
    color: var(--text-secondary);
    line-height: 1.5;
  }
</style>
