---
import { site } from '../content/site';
---

<section class="section" id="screenshots" aria-labelledby="screenshots-heading">
  <div class="container">
    <h2 id="screenshots-heading">See it in action</h2>
  </div>
  <div class="gallery-scroll">
    {site.screenshots.map((screenshot) => (
      <figure class="gallery-card">
        <div class="gallery-image-wrap">
          <!-- TODO: Replace placeholder when real screenshots are available -->
          <div class="gallery-placeholder">
            <span>Screenshot coming soon</span>
          </div>
          <!--
          <img
            src={screenshot.src}
            alt={screenshot.alt}
            loading="lazy"
            decoding="async"
            width="390"
            height="844"
          />
          -->
        </div>
        <figcaption>{screenshot.caption}</figcaption>
      </figure>
    ))}
  </div>
</section>

<style>
  .gallery-scroll {
    display: flex;
    gap: var(--element-gap);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-inline: var(--content-padding);
    padding-bottom: 1rem;
    -webkit-overflow-scrolling: touch;
  }

  /* Hide scrollbar but keep scrollable */
  .gallery-scroll {
    scrollbar-width: thin;
    scrollbar-color: var(--surface-border) transparent;
  }

  .gallery-card {
    flex: 0 0 auto;
    width: clamp(260px, 40vw, 340px);
    scroll-snap-align: center;
  }

  .gallery-image-wrap {
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 9 / 16;
  }

  .gallery-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    font-size: var(--small);
  }

  .gallery-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  figcaption {
    margin-top: 0.75rem;
    font-size: var(--small);
    color: var(--text-secondary);
    line-height: 1.5;
  }
</style>
