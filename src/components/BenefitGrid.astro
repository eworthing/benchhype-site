---
import { site } from '../content/site';

const icons = [
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="1" x2="23" y2="23"/><path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55"/><path d="M5 12.55a10.94 10.94 0 0 1 5.17-2.39"/><path d="M10.71 5.05A16 16 0 0 1 22.56 9"/><path d="M1.42 9a15.91 15.91 0 0 1 4.7-2.88"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/></svg>`,
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
];
---

<section class="section section-alt" id="benefits" aria-labelledby="benefits-heading">
  <div class="container">
    <h2 id="benefits-heading">Why BenchHype</h2>
    <div class="benefit-grid">
      {site.benefits.map((benefit, i) => (
        <div class:list={['card', { 'card-featured': i === 0 }]}>
          <div class:list={['benefit-icon', { 'benefit-icon-accent': i === 0 }]}>
            <Fragment set:html={icons[i]} />
          </div>
          <h3>{benefit.title}</h3>
          <p>{benefit.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  h2 {
    margin-bottom: 3rem;
  }

  .benefit-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--element-gap);
  }

  .card-featured {
    grid-column: 1 / -1;
    border-top: 2px solid var(--accent);
  }

  .card-featured h3 {
    font-size: var(--h2);
  }

  .card-featured p {
    max-width: 640px;
  }

  .benefit-icon {
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
  }

  .benefit-icon-accent {
    color: var(--accent);
  }

  .benefit-grid h3 {
    margin-bottom: 0.75rem;
  }

  @media (max-width: 640px) {
    .benefit-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
