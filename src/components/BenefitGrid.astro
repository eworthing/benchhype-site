---
import { site } from '../content/site';
---

<section class="section section-alt" id="benefits" aria-labelledby="benefits-heading">
  <div class="container">
    <h2 id="benefits-heading">Why BenchHype</h2>
    <div class="benefit-grid">
      {site.benefits.map((benefit, i) => (
        <div class:list={['card', { 'card-featured': i === 0 }]}>
          <h3>{benefit.title}</h3>
          <p>{benefit.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  h2 {
    margin-bottom: 3rem;
  }

  .benefit-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--element-gap);
  }

  /* First card spans full width — the star of this section */
  .card-featured {
    grid-column: 1 / -1;
    border-top: 2px solid var(--accent);
  }

  .card-featured h3 {
    font-size: var(--h2);
  }

  .card-featured p {
    max-width: 640px;
  }

  .benefit-grid h3 {
    margin-bottom: 0.75rem;
  }

  @media (max-width: 640px) {
    .benefit-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
