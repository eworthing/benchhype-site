---
import { site } from '../content/site';
---

<section class="section section-alt" id="features" aria-labelledby="features-heading">
  <div class="container">
    <h2 id="features-heading">Features</h2>
    <div class="feature-list">
      {site.features.map((feature, i) => (
        <div class:list={['feature-row', { 'feature-row-reverse': i % 2 !== 0 }]}>
          <div class="feature-text">
            <h3>{feature.title}</h3>
            <p class="feature-summary">{feature.summary}</p>
            <ul>
              {feature.bullets.map((bullet) => (
                <li>{bullet}</li>
              ))}
            </ul>
          </div>
          <div class="feature-detail">
            <img
              src={feature.image}
              alt={feature.summary}
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  h2 {
    margin-bottom: 3rem;
  }

  .feature-list {
    display: flex;
    flex-direction: column;
    gap: var(--group-gap);
  }

  .feature-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .feature-row-reverse {
    direction: rtl;
  }

  .feature-row-reverse > * {
    direction: ltr;
  }

  .feature-text {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .feature-summary {
    color: var(--text-secondary);
  }

  ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  li {
    color: var(--text-secondary);
    font-size: var(--small);
    padding-left: 1.25rem;
    position: relative;
  }

  li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--bullet);
  }

  .feature-detail {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .feature-detail img {
    width: 100%;
    aspect-ratio: 1151 / 800;
    object-fit: cover;
    border-radius: var(--radius);
  }

  @media (max-width: 768px) {
    .feature-row,
    .feature-row-reverse {
      grid-template-columns: 1fr;
      direction: ltr;
    }

    .feature-detail {
      order: -1;
    }
  }
</style>
