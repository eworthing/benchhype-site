---
import { site } from '../content/site';

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <nav class="footer-links" aria-label="Footer navigation">
      <a href={`${import.meta.env.BASE_URL}support`}>Support</a>
      <a href={`${import.meta.env.BASE_URL}privacy`}>Privacy</a>
      <a href={`${import.meta.env.BASE_URL}faq`}>FAQ</a>
    </nav>
    <p class="footer-copy">&copy; {currentYear} {site.name}. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--surface-border);
    padding-block: 2.5rem;
    margin-top: var(--section-gap);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .footer-links {
    display: flex;
    gap: 2rem;
  }

  .footer-links a {
    color: var(--text-secondary);
    font-size: var(--small);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--text-primary);
  }

  .footer-copy {
    font-size: var(--small);
    color: var(--text-secondary);
  }
</style>
