---
import { site } from '../content/site';
---

<section class="hero section" id="hero">
  <div class="container hero-grid">
    <div class="hero-text">
      <h1>{site.tagline}</h1>
      <p class="hero-description">{site.description}</p>
      <p class="hero-audience">{site.heroAudience}</p>
      <div class="hero-ctas">
        <a href={site.ctaPrimary.href} class="btn btn-primary">{site.ctaPrimary.label}</a>
        <a href={site.ctaSecondary.href} class="btn btn-secondary">{site.ctaSecondary.label}</a>
      </div>
    </div>
    <div class="hero-visual">
      <!-- TODO: Replace with real device mockup or screenshot -->
      <div class="hero-placeholder">
        <div class="placeholder-device">
          <div class="placeholder-screen">
            <span>Screenshot coming soon</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: 5rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hero-description {
    font-size: 1.1875rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  .hero-audience {
    font-size: 1rem;
    color: var(--text-secondary);
    opacity: 0.8;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-placeholder {
    width: 100%;
    max-width: 320px;
  }

  .placeholder-device {
    aspect-ratio: 9 / 16;
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: 24px;
    padding: 12px;
    width: 100%;
  }

  .placeholder-screen {
    width: 100%;
    height: 100%;
    background: var(--bg);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .placeholder-screen span {
    color: var(--text-secondary);
    font-size: var(--small);
  }

  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .hero-visual {
      order: -1;
    }

    .hero-placeholder {
      max-width: 240px;
    }

    .hero {
      padding-top: 3rem;
    }

    .hero-ctas {
      justify-content: center;
    }

    .hero-text {
      text-align: center;
    }
  }
</style>
