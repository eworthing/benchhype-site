---
import { site } from '../content/site';
---

<section class="hero section" id="hero">
  <div class="container hero-grid">
    <div class="hero-text">
      <h1>{site.tagline}</h1>
      <p class="hero-description">{site.description}</p>
      <p class="hero-audience">{site.heroAudience}</p>
      <div class="hero-ctas">
        <a href={site.ctaPrimary.href} class="btn btn-primary">{site.ctaPrimary.label}</a>
        <a href={site.ctaSecondary.href} class="btn btn-secondary">{site.ctaSecondary.label}</a>
      </div>
      <div class="hero-badges">
        {site.badges.map((badge) => (
          <span class="badge">{badge}</span>
        ))}
      </div>
    </div>
    <div class="hero-visual">
      <div class="device-frame">
        <div class="device-screen">
          <div class="device-statusbar">
            <span class="device-time">9:41</span>
          </div>
          <div class="soundboard-grid">
            <div class="sb-tile sb-active">
              <span class="sb-label">Airhorn</span>
            </div>
            <div class="sb-tile">
              <span class="sb-label">Anthem</span>
            </div>
            <div class="sb-tile">
              <span class="sb-label">Crowd</span>
            </div>
            <div class="sb-tile">
              <span class="sb-label">Whistle</span>
            </div>
            <div class="sb-tile sb-playing">
              <span class="sb-label">Buzzer</span>
            </div>
            <div class="sb-tile">
              <span class="sb-label">Organ</span>
            </div>
            <div class="sb-tile">
              <span class="sb-label">Defense</span>
            </div>
            <div class="sb-tile">
              <span class="sb-label">Strike</span>
            </div>
            <div class="sb-tile">
              <span class="sb-label">Charge</span>
            </div>
            <div class="sb-tile">
              <span class="sb-label">Timeout</span>
            </div>
            <div class="sb-tile">
              <span class="sb-label">Slap</span>
            </div>
            <div class="sb-tile">
              <span class="sb-label">Win</span>
            </div>
          </div>
          <div class="device-player">
            <div class="player-icon">&#9654;</div>
            <div class="player-info">
              <span class="player-title">Game Opener Mix</span>
              <div class="player-progress">
                <div class="player-progress-fill"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: 5rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hero-description {
    font-size: 1.1875rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  .hero-audience {
    font-size: 0.9375rem;
    color: var(--text-secondary);
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
  }

  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  /* Device mockup — flat, no effects */
  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .device-frame {
    width: 280px;
    height: 580px;
    background: var(--surface);
    border-radius: 2.5rem;
    border: 4px solid var(--surface-border);
    overflow: hidden;
  }

  .device-screen {
    width: 100%;
    height: 100%;
    background: var(--bg);
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .device-statusbar {
    display: flex;
    justify-content: center;
    padding: 4px 8px;
  }

  .device-time {
    color: var(--text-secondary);
    font-size: 10px;
    font-weight: 700;
  }

  .soundboard-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
    flex: 1;
  }

  .sb-tile {
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sb-active {
    background: rgba(230, 57, 70, 0.15);
    border-color: rgba(230, 57, 70, 0.3);
  }

  .sb-playing {
    background: var(--accent);
    border-color: var(--accent);
  }

  .sb-label {
    font-size: 7px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
  }

  .sb-active .sb-label {
    color: var(--accent);
  }

  .sb-playing .sb-label {
    color: #fff;
  }

  .device-player {
    background: var(--surface);
    border: 1px solid var(--surface-border);
    padding: 8px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: auto;
  }

  .player-icon {
    width: 28px;
    height: 28px;
    background: var(--accent);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 10px;
  }

  .player-info {
    flex: 1;
    overflow: hidden;
  }

  .player-title {
    font-size: 8px;
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }

  .player-progress {
    width: 100%;
    height: 3px;
    background: var(--surface-border);
    border-radius: 2px;
    margin-top: 4px;
    overflow: hidden;
  }

  .player-progress-fill {
    width: 33%;
    height: 100%;
    background: var(--accent);
    border-radius: 2px;
  }

  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .hero-visual {
      order: -1;
    }

    .hero {
      padding-top: 3rem;
    }

    .hero-ctas {
      justify-content: center;
    }

    .hero-badges {
      justify-content: center;
    }

    .hero-text {
      text-align: center;
    }

    .device-frame {
      width: 220px;
      height: 460px;
    }
  }
</style>
