---
import { site } from '../content/site';
---

<section class="badge-section section-compact" aria-label="Key features">
  <div class="container badge-row">
    {site.badges.map((badge) => (
      <span class="badge">{badge}</span>
    ))}
  </div>
</section>

<style>
  .badge-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }
</style>
