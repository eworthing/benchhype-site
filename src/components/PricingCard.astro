---
import { site } from '../content/site';

const { free, pro } = site.pricing;
---

<section class="section section-alt" id="pricing" aria-labelledby="pricing-heading">
  <div class="container">
    <h2 id="pricing-heading">Free vs Pro</h2>
    <div class="pricing-grid">
      <div class="card pricing-card">
        <h3>{free.title}</h3>
        <p class="pricing-desc">{free.description}</p>
        <ul>
          {free.limits.map((item) => (
            <li>
              <svg class="check-icon check-muted" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M13.3 4.3l-7 7L3 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {item}
            </li>
          ))}
        </ul>
        <div class="pricing-price">
          <span class="price-value">Free</span>
        </div>
      </div>

      <div class="card pricing-card pricing-pro">
        <span class="pro-label">Recommended</span>
        <h3>{pro.title}</h3>
        <p class="pricing-desc">{pro.description}</p>
        <ul>
          {pro.features.map((item) => (
            <li class="pro-item">
              <svg class="check-icon check-accent" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M13.3 4.3l-7 7L3 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {item}
            </li>
          ))}
        </ul>
        <div class="pricing-price">
          <span class="price-value">{pro.price}</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  h2 {
    margin-bottom: 3rem;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--element-gap);
    max-width: 720px;
  }

  .pricing-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Pro card: structural differentiation only */
  .pricing-pro {
    border-color: var(--accent);
    padding: 2.5rem;
  }

  .pro-label {
    color: var(--accent);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .pricing-desc {
    font-size: var(--small);
  }

  ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  li {
    font-size: var(--small);
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .pro-item {
    color: var(--text-primary);
  }

  .check-icon {
    flex-shrink: 0;
  }

  .check-muted {
    color: var(--text-secondary);
  }

  .check-accent {
    color: var(--accent);
  }

  .pricing-price {
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid var(--surface-border);
  }

  .price-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  @media (max-width: 640px) {
    .pricing-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
