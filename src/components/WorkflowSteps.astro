---
import { site } from '../content/site';
---

<section class="section" id="workflow" aria-labelledby="workflow-heading">
  <div class="container">
    <h2 id="workflow-heading">Game-day workflow</h2>
    <p class="workflow-intro">BenchHype supports an end-to-end workflow, from setup to post-game review.</p>
    <ol class="timeline">
      {site.workflow.map((item, i) => (
        <li class="timeline-item">
          <div class="timeline-marker">
            <span class="step-number">{i + 1}</span>
          </div>
          <div class="timeline-content">
            <h3>{item.step}</h3>
            <p>{item.detail}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  h2 {
    margin-bottom: 1rem;
  }

  .workflow-intro {
    margin-bottom: 3rem;
  }

  .timeline {
    list-style: none;
    padding: 0;
    position: relative;
    max-width: 640px;
  }

  /* Connector line */
  .timeline::before {
    content: '';
    position: absolute;
    left: 17px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--surface-border);
  }

  .timeline-item {
    display: flex;
    gap: 1.5rem;
    padding-bottom: 2.5rem;
    position: relative;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-marker {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
  }

  .step-number {
    color: #fff;
    font-size: var(--small);
    font-weight: 700;
  }

  .timeline-content {
    padding-top: 0.25rem;
  }

  .timeline-content h3 {
    margin-bottom: 0.25rem;
  }

  .timeline-content p {
    font-size: var(--small);
  }
</style>
