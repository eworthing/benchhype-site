---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../content/site';
---

<BaseLayout title={`Page Not Found — ${site.name}`} description="The page you're looking for doesn't exist.">
  <section class="section container not-found">
    <h1>404</h1>
    <p>The page you're looking for doesn't exist.</p>
    <a href={`${import.meta.env.BASE_URL}`} class="btn btn-secondary">Back to Home</a>
  </section>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    min-height: 50vh;
    justify-content: center;
  }

  .not-found h1 {
    font-size: clamp(4rem, 10vw, 8rem);
    color: var(--accent);
    line-height: 1;
  }
</style>
